{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/components/(.*).js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/pages/(.*).js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/styles/(.*).css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/arutala", "destination": "/arutala.html" },
    { "source": "/basketball", "destination": "/basketball.html" },
    { "source": "/cat-feeder", "destination": "/cat-feeder.html" },
    { "source": "/chat", "destination": "/chat.html" },
    { "source": "/chess", "destination": "/chess.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/experience", "destination": "/experience.html" },
    { "source": "/game", "destination": "/game.html" },
    { "source": "/gesture", "destination": "/gesture.html" },
    { "source": "/healthy-lifestyle-recommendation", "destination": "/healthy-lifestyle-recommendation.html" },
    { "source": "/import", "destination": "/import.html" },
    { "source": "/indollnet", "destination": "/indollnet.html" },
    { "source": "/milk-spray-drying", "destination": "/milk-spray-drying.html" },
    { "source": "/moba", "destination": "/moba.html" },
    { "source": "/multispektral", "destination": "/multispektral.html" },
    { "source": "/og-image", "destination": "/og-image.html" },
    { "source": "/origin", "destination": "/origin.html" },
    { "source": "/projects", "destination": "/projects.html" },
    { "source": "/publications", "destination": "/publications.html" },
    { "source": "/rpg", "destination": "/rpg.html" },
    { "source": "/sabdarana", "destination": "/sabdarana.html" },
    { "source": "/seir-model", "destination": "/seir-model.html" },
    { "source": "/skills", "destination": "/skills.html" },
    { "source": "/talks", "destination": "/talks.html" },
    { "source": "/(.*)", "destination": "/404.html" }
  ]
}
